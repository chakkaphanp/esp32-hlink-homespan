#define TFT_CS    14
#define TFT_DC    15
#define TFT_RST   21
#define TFT_MOSI  6
#define TFT_SCLK  7
#define TFT_BL    22  // LCD Backlight (Set HIGH to turn on)


/* LVGL display resolution */
