  // Create Date Label
  ui_date_label = lv_label_create(lv_scr_act());
  lv_obj_align(ui_date_label, LV_ALIGN_CENTER, 0, -50);
  lv_obj_set_style_text_font(ui_date_label, &lv_font_montserrat_24, 0);
