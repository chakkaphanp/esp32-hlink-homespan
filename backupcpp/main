  delay(5000); // Short delay to ensure IR receiver is ready
  Serial.println("Setup complete!");
}

void loop() {
  // Keep LVGL timers running
  //lv_timer_handler(); 

  static unsigned long lastMillis = 0;
  static unsigned long lastSensorMillis = 0;
    
  // Update sensor data every 5 seconds
  /*if (millis() - lastSensorMillis > 10000) {
    lastSensorMillis = millis();
    updateSensorData();
  }*/

  // Check for incoming IR signals
  if (irrecv.decode(&results)) {
    Serial.print("IR Protocol: ");
    Serial.print(typeToString(results.decode_type));
    Serial.print(", Code: 0x");
    Serial.println((uint32_t)results.value, HEX);

    if (ui_ir_label) {
      char irStr[32];
      if (results.decode_type == UNKNOWN) {
        snprintf(irStr, sizeof(irStr), "IR: UNKNOWN");
      } else {
        snprintf(irStr, sizeof(irStr), "IR: 0x%X", (uint32_t)results.value);
      }
      lv_label_set_text(ui_ir_label, irStr);
    }    

    irrecv.resume(); // Enable receiving of the next value
  }
  //Serial.println("Loop running...");
  delay(500); // Give the system some time to breathe
}
